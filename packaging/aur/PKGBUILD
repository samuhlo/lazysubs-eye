# Maintainer: Samuel López (samuhlo) <samuhlodev@gmail.com>
pkgname=lazysubs-eye-bin
pkgver=0.13.0
pkgrel=1
pkgdesc="AI subscription quota monitor for Omarchy (waybar + TUI)"
arch=('x86_64')
url="https://github.com/samuhlo/lazysubs-eye"
license=('MIT')
provides=('lazysubs-eye')
conflicts=('lazysubs-eye')
optdepends=(
  'waybar: status bar module (the TUI works standalone too)'
  'hyprland: floating TUI window rule (skipped on other compositors)'
  'xdg-terminal-exec: left-click TUI launcher outside Omarchy'
)
source=("$url/releases/download/v$pkgver/lazysubs-eye-$pkgver-x86_64-linux-musl.tar.gz")
sha256sums=('661e8741c0b9dc0262760350110fa77774a36a2bf203d459c1e86e549b780579')

package() {
  cd "lazysubs-eye-$pkgver-x86_64-linux-musl"
  install -Dm755 lazysubs-eye "$pkgdir/usr/bin/lazysubs-eye"
  install -Dm644 LICENSE "$pkgdir/usr/share/licenses/$pkgname/LICENSE"
  install -Dm644 README.md "$pkgdir/usr/share/doc/$pkgname/README.md"
}
